# AstroPath backend environment
# Copy to .env for local development

# HTTP
PORT=8080
NODE_ENV=development

# CORS - comma-separated origins allowed to call the API
CORS_ORIGINS=http://localhost:3000,http://localhost:8081,capacitor://localhost

# Firestore / Firebase Admin
# If FIRESTORE_MODE=memory, the server uses an in-memory mock Firestore and
# does NOT require any credentials. Use this for local development and
# contract testing against the frontend mocks.
# If FIRESTORE_MODE=firestore, the server uses real Firestore via firebase-admin.
# It then expects GOOGLE_APPLICATION_CREDENTIALS to point at a service account JSON
# OR FIREBASE_PROJECT_ID + application default credentials.
FIRESTORE_MODE=memory
FIREBASE_PROJECT_ID=
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_APP_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# Auth
# If AUTH_MODE=bypass, every request is allowed and gets a synthetic dev user.
# Use during frontend integration. Never use in staging/prod.
# If AUTH_MODE=firebase, requests must carry a Firebase ID token via
# Authorization: Bearer <token> and the backend verifies it with firebase-admin.
AUTH_MODE=bypass
DEV_USER_ID=dev-user-001
DEV_USER_EMAIL=dev@astropath.local
